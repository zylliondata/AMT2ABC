        "type": "javascript",
        "script": "/* 构建提交参数，当接收到 CAPA ID 参数时默认为修改操作，构建修改参数 */\nlet saveData = {\n  \"resourceId\": resourceId.value ?? \"\",\n  \"businessKey\": \"CAPA\",\n  \"correlationId\": uuid.v4(),\n  \"parameters\": {\n    \"capaId\": input1.value ?? \"\",\n    \"description\": textarea1.value ?? \"\",\n    \"dueDate\": `${datePicker1.formattedValue}T${timePicker1.value}+8:00`,\n    \"assigneeId\": select2.value ?? \"\",\n    \"userId\": currentUser.data?.id ?? \"\",\n    \"tenantId\": currentUser.data?.tenant?.id ?? \"\"\n  }\n}\nif (capaId.value && capaId.value.length > 0) {\n  saveData[\"action\"] = \"UPDATE_CAPA\";\n} else {\n  saveData[\"action\"] = \"CREATE_CAPA\";\n  if (sourceRef.value && sourceRef.value.length > 0) {\n    saveData[\"action\"][\"parameters\"][\"sourceRef\"] = sourceRef.value;\n  }\n}\n\nif (fileUpload1.files && fileUpload1.files.length > 0) {\n  saveData[\"parameters\"][\"attachmentUrl\"] = fileUpload1.files[0].url;\n} else if (cv_capa.value.attachment_url.url.length > 0) {\n  saveData[\"parameters\"][\"attachmentUrl\"] = cv_capa.value.attachment_url.url;\n};\n\ncv_saveData.setValue(saveData);"
