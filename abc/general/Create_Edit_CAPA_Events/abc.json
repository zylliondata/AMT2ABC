        "name": "eca_parseFileUrl",
        "depQueryName": "",
        "delayTime": "",
        "id": "ffbdb869-bdc0-4e52-8694-708c7b0ca9d9",
        "triggerType": "manual",
        "type": "javascript",
        "script": "/**\n * 将查询结果赋值\n * 纯本地解析文件链接，无网络请求\n * @param {string} url 文件地址\n * @returns {\n *   fileName: string,      // 完整文件名\n *   suffix: string,        // 小写后缀\n *   category: string      // 文件分类：图片 / PDF文档 / Word文档 / Excel表格 / 未知\n * }\n */\nfunction parseFileUrlLocal(url) {\n  // 取最后一段文件名\n  const fileName = url.split('/').pop();\n  const arr = fileName.split('.');\n  const suffix = arr.length >= 2 ? arr.pop().toLowerCase() : '';\n\n  let category = '未知';\n\n  // 图片后缀集合\n  const imgExt = ['png', 'jpg', 'jpeg', 'gif', 'bmp', 'webp', 'svg'];\n  // File文档\n  const fileExt = ['doc', 'docx', 'pdf', 'xls', 'xlsx'];\n\n  if (imgExt.includes(suffix)) {\n    category = \"image\";\n  } else if (fileExt.includes(suffix)) {\n    category = \"file\";\n  }\n\n  return {\n    \"fileName\": fileName,\n    \"url\": url,\n    \"category\": category\n  };\n}\n\nconst resultList = [...(eca_searchCAPA.data?.data?.result ?? [])];\nif (resultList.length > 0) {\n  let result = {...resultList[0]};\n  if (Object.keys(result).length > 0) {\n    const attachmentUrl = result.attachment_url;\n    if (attachmentUrl && attachmentUrl.length > 0) {\n      result[\"attachment_url\"] = parseFileUrlLocal(attachmentUrl);\n    };\n    cv_capa.setValue(result);\n  };\n};\n"
      },
